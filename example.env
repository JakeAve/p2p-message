# Copy this file to .env and fill in the values you need.
# Everything below is optional — the app works with no .env at all,
# falling back to Google's public STUN servers and no TURN relay.

# Port the server listens on.
# PORT=8000

# --- TURN: Cloudflare Realtime (recommended) -------------------------------
# Pay-per-GB relayed, no self-hosted coturn needed. Create a Turn app under
# Realtime in the Cloudflare dashboard to get these values. When both are
# set, they take priority over the self-hosted TURN_* vars below.
# CLOUDFLARE_TURN_KEY_ID=
# CLOUDFLARE_TURN_TOKEN=
# CLOUDFLARE_TURN_TTL=86400

# --- ICE: STUN servers -------------------------------------------------------
# Comma-separated stun: URLs. Unset falls back to Google's public STUN.
# ICE_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# --- TURN: self-hosted coturn (alternative to Cloudflare above) ------------
# Comma-separated turn:/turns: URLs.
# ICE_TURN_SERVERS=turn:your-coturn-host:3478?transport=udp
# Shared secret configured as coturn's static-auth-secret.
# TURN_STATIC_SECRET=
# TURN_CREDENTIAL_TTL=3600

# --- Room recovery (only needed if you can't guarantee a single always-on
# instance — e.g. serverless/edge hosting like Deno Deploy, where an isolate
# can restart mid-session). Rooms otherwise live only in process memory, by
# design (see docs/self-hosting.md). Leave unset on a single-instance host.
# Generate with `deno task gen-secret` (or `openssl rand -base64 48`). Must
# stay stable across restarts/deploys — it's what lets a fresh instance
# verify a room a previous one issued.
# ROOM_RECOVERY_SECRET=
# How long, in ms, a *paired* room stays recoverable after an instance loses
# it. Default 21600000 (6 hours). Doesn't apply before pairing — an
# un-paired invite is always bounded by its own invite window instead.
# ROOM_RECOVERY_MAX_AGE_MS=21600000
